# Build: SOCKS proxy on host (listens 0.0.0.0:SOCKS_PORT during `docker compose build`)
SOCKS_PORT=1080
# Rootful Docker: leave unset (compose defaults to host-gateway; Dockerfile auto-detects bridge IP).
# Rootless Docker: set automatically by docker/build_wrapper.py build (often 10.0.2.2).
# HOST_GATEWAY_IP=10.0.2.2

# Host project directories (bind-mount into container)
PROJECT_PATH_1=/absolute/path/to/proj1
# PROJECT_PATH_2=/absolute/path/to/proj2
# PROJECT_PATH_3=/absolute/path/to/proj3

# Which compose files to merge (add fragments when using proj2/proj3)
COMPOSE_FILE=docker-compose.yml
# COMPOSE_FILE=docker-compose.yml:docker/compose.proj2.yml
# COMPOSE_FILE=docker-compose.yml:docker/compose.proj2.yml:docker/compose.proj3.yml

# inf-splitter: config and secrets on host (edit config/inf-splitter.toml in inf-splitter repo)
# INF_SPLITTER_CONFIG_DIR=../inf-splitter.git
# cp -r ../inf-splitter.git/secrets.example ../inf-splitter.git/secrets
# INF_SPLITTER_SECRETS_DIR=../inf-splitter.git/secrets

# inf-splitter routing
PROXY_PORT=3000
# IP для доступа к хосту из докер-контейнера (нужно для rootless docker, 
# используйте build_wrapper.py для установки)
# HOST_GATEWAY_IP=10.0.2.2

# Build-time toolchain versions
NODE_VERSION=22.12.0
YARN_VERSION=4.15.0
ASTRO_VERSION=6.4.2
DEV_UID=1000
DEV_GID=1000

# At container start, chown bind-mounted work dirs to dev:dev (fixes EACCES on root-owned mounts)
CHOWN_WORK_ON_START=1

# Claude installer target at image build (stable|latest|X.Y.Z)
# CLAUDE_TARGET=stable

# Runtime model settings for Claude Code
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=gemma4:31b
CLAUDE_CODE_SUBAGENT_MODEL=gemma4:31b
CLAUDE_CODE_EFFORT_LEVEL=max
