# Build: SOCKS proxy on host (used only during `docker compose build`)
SOCKS_PORT=1080
# IP/host reachable from the build container (LAN IP of this machine; not 127.0.0.1)
# Required for rootless Docker (no docker0 / 172.17.0.1). Optional on classic bridge.
SOCKS_HOST=192.168.1.100

# Host project directories (bind-mount into container)
PROJECT_PATH_1=/absolute/path/to/proj1
# PROJECT_PATH_2=/absolute/path/to/proj2
# PROJECT_PATH_3=/absolute/path/to/proj3

# Which compose files to merge (add fragments when using proj2/proj3)
COMPOSE_FILE=docker-compose.yml
# COMPOSE_FILE=docker-compose.yml:docker/compose.proj2.yml
# COMPOSE_FILE=docker-compose.yml:docker/compose.proj2.yml:docker/compose.proj3.yml

# Runtime: Ollama on host
OLLAMA_PORT=11434

# DeepSeek API key (Anthropic-compatible endpoint for Claude Code; used by claude container only)
DEEPSEEK_API_KEY=

# inf-splitter routing (proxy does not manage API keys — auth headers pass through to DeepSeek)
PROXY_PORT=3000
LOCAL_MODELS=gemma4:31b
DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# Docker network mode for Ollama reachability from inf-splitter:
#   rootful   -> http://host.docker.internal:${OLLAMA_PORT}
#   rootless  -> http://${EXTERNAL_IP:-$SOCKS_HOST}:${OLLAMA_PORT}
DOCKER_NETWORK_MODE=rootful
# EXTERNAL_IP=10.213.12.7
# OLLAMA_BASE_URL=http://192.168.1.100:11434

# Build-time toolchain versions
NODE_VERSION=22.12.0
YARN_VERSION=4.15.0
ASTRO_VERSION=6.4.2
DEV_UID=1000
DEV_GID=1000

# At container start, chown bind-mounted work dirs to dev:dev (fixes EACCES on root-owned mounts)
CHOWN_WORK_ON_START=1

# Claude installer target at image build (stable|latest|X.Y.Z)
# CLAUDE_TARGET=stable

# Runtime model settings for Claude Code
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=gemma4:31b
CLAUDE_CODE_SUBAGENT_MODEL=gemma4:31b
CLAUDE_CODE_EFFORT_LEVEL=max
